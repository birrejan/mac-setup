# Brewfile.optional — tooling that is NOT installed by default.
#
# Uncomment what you need, then run:
#   brew bundle --file=Brewfile.optional
#
# Everything here is intentionally kept out of the main Brewfile so a fresh
# machine stays lean. Enable as the new job's stack becomes clear.

